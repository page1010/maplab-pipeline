# MAPLAB Pipeline — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Google OAuth ──────────────────────────────────────────────
# Download from Google Cloud Console → OAuth 2.0 Credentials
# Place as ./auth/credentials.json (not needed in .env)

# ─── Google APIs ───────────────────────────────────────────────
# Google Sheets: ID from URL https://docs.google.com/spreadsheets/d/[SHEET_ID]/
MAPLAB_QUOTES_SHEET_ID=your_sheet_id_here

# Google Drive: ID of root archive folder (MAPLAB_Assets)
# Get from Drive URL: https://drive.google.com/drive/folders/[FOLDER_ID]
GOOGLE_DRIVE_ARCHIVE_FOLDER_ID=your_folder_id_here

# ─── Gemini AI ─────────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Notion ────────────────────────────────────────────────────
# Integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_your_token_here

# Database ID from Notion URL: notion.so/[workspace]/[DATABASE_ID]?v=...
NOTION_DATABASE_ID=your_notion_database_id_here

# ─── Pipeline Config ───────────────────────────────────────────
# Days to look back when no prior run state found
DEFAULT_LOOKBACK_DAYS=7

# Date tolerance for Sheets quote matching (prep photos day before event)
DATE_TOLERANCE_DAYS=1

# WebP quality (0-100, recommended: 75-85)
WEBP_QUALITY=80

# Max image width in pixels
MAX_IMAGE_WIDTH=2000
